class Solution:
    def judgeSquareSum(self, c: int) -> bool:
        
        low = 0
        high = int(sqrt(c))

        while low<=high:
            sum = low*low+high*high
            if sum==c:
                return True
            elif sum<c:
                low+=1
            else :
                high-=1
        return False
            
        
